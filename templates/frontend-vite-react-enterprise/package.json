  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "jest",
    "lint": "eslint .",
    "preview": "vite preview",
    "cy:dev": "cross-env VITE_USE_MSW=true vite --host 0.0.0.0 --port 51730",
    "cy:e2e": "start-server-and-test cy:dev http://localhost:51730 \"cypress open\"",
    "cy:e2e:run": "start-server-and-test cy:dev http://localhost:51730 \"cypress run --e2e\"",
    "cy:dev:real": "vite --host 0.0.0.0 --port 51730",
    "cy:e2e:real": "start-server-and-test cy:dev:real http://localhost:51730 \"cypress open\""
  },
